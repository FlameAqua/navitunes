    <!-- Counted quantities.
         Polish has four plural forms (one / few / many / other) where English has two:
         1 piosenka, 2-4 piosenki, 5+ piosenek. Anything counted MUST live here rather than
         being assembled inline as "song" + "s", or it reads as broken Polish. -->
    <plurals name="n_songs">
        <item quantity="one">%d song</item>
        <item quantity="other">%d songs</item>
    </plurals>
    <plurals name="n_albums">
