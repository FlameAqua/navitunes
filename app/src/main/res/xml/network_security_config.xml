<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        HTTPS is strongly preferred. Cleartext is permitted because users may
        run Navidrome on a private LAN (e.g. http://192.168.x.x:4533).
        The login screen warns when a non-HTTPS URL is entered.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" overridePins="false" />
        </trust-anchors>
    </base-config>
</network-security-config>
